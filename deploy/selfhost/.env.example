# SELF-HOST — свой инстанс
# install.sh создаёт .env автоматически
#
# APP_ENV=production — обязателен JWT_SECRET (≥16 символов)
# APP_ENV=development или пусто — допускается dev-secret (только для тестов)

SERVER_DOMAIN=localhost

JWT_SECRET=
POSTGRES_PASSWORD=
MINIO_ROOT_PASSWORD=

POSTGRES_USER=messenger
POSTGRES_DB=messenger
DB_ENCRYPTION_KEY=
MINIO_ROOT_USER=minioadmin
S3_BUCKET=messenger-media

# Для HTTPS (nip.io или свой домен)
# LETSENCRYPT_EMAIL=you@example.com

# Push (опционально): docker run --rm node:20-alpine npx web-push generate-vapid-keys
# PUSH_VAPID_PUBLIC_KEY=
# PUSH_VAPID_PRIVATE_KEY=

# Федерация: main_only — общение только через главный (по умолчанию для self-host)
FEDERATION_MODE=main_only
FEDERATION_MAIN_DOMAIN=astralrelay.online
# mTLS (опционально): пути к клиентскому сертификату
# FEDERATION_MTLS_CLIENT_CERT=/path/to/client-cert.pem
# FEDERATION_MTLS_CLIENT_KEY=/path/to/client-key.pem
# Webhook-алерты (опционально): POST при rate limit / blocklist
# FEDERATION_ALERT_WEBHOOK_URL=https://hooks.example.com/federation-alerts

VPN_XRAY_ENABLED=false
# При nip.io: VPN_XRAY_ENDPOINT=1.2.3.4.nip.io:10444
VPN_XRAY_ENDPOINT=
VPN_XRAY_API_ADDR=xray:10085
