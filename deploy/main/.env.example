# MAIN — hub-сервер (продакшен)
# Скопируйте: cp .env.example .env
# Чеклист: SERVER_DOMAIN, JWT_SECRET, POSTGRES_PASSWORD, MINIO_ROOT_PASSWORD

# Окружение: production / prod — обязателен JWT_SECRET (≥16 символов)
APP_ENV=production

# Домен (обязательно для федерации и CORS)
SERVER_DOMAIN=your-domain.example

# Секреты (обязательно!)
JWT_SECRET=
POSTGRES_PASSWORD=
MINIO_ROOT_PASSWORD=

# Шифрование БД (рекомендуется): openssl rand -base64 32
DB_ENCRYPTION_KEY=

POSTGRES_USER=messenger
POSTGRES_DB=messenger

MINIO_ROOT_USER=minioadmin
S3_BUCKET=messenger-media

# HTTPS: обязателен для Let's Encrypt (валидный email, не changeme@example.com)
LETSENCRYPT_EMAIL=admin@astralrelay.online

# Push-уведомления (опционально): npx web-push generate-vapid-keys
# PUSH_VAPID_PUBLIC_KEY=
# PUSH_VAPID_PRIVATE_KEY=

# Федерация: защита (по умолчанию авто)
# FEDERATION_RATE_LIMIT=100
# FEDERATION_ALLOWLIST_MODE=auto
# FEDERATION_BLOCKLIST_PATH=/data/federation_blocklist.txt
